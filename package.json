{
  "name": "remux",
  "version": "1.0.0",
  "workspaces": [
    "app",
    "extensions/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "cargo run -p remux -- start --foreground",
    "build:runtime": "cargo build --release -p remux",
    "app:typecheck": "npm --workspace @remux/app run typecheck",
    "mobile:typecheck": "npm --workspace @remux/app run typecheck",
    "viewers:build": "npm --workspaces --if-present run build",
    "typecheck": "tsc --noEmit && node scripts/typecheck-linked-viewers.mjs",
    "lint": "npm run typecheck",
    "test:runtime": "cargo test -p remux",
    "test:codex-server": "cargo test --manifest-path extensions/codex/server/Cargo.toml --offline",
    "test:codex": "playwright test -c extensions/codex/playwright.config.ts",
    "test:narrate": "npm --workspace @remux/narrate test",
    "test:narration-client": "npm --workspace @remux/narration-client test",
    "build:codex:narration-real": "npm --workspace @remux/codex run build && npm --workspace @remux/narrate run build && cargo build --release -p remux --offline && cargo build --release --manifest-path extensions/codex/server/Cargo.toml --target-dir /tmp/remux-codex-server-target --offline && cargo build --release --manifest-path extensions/narrate/server/Cargo.toml --target-dir /tmp/remux-narrate-server-target --offline",
    "test:codex:narration-real": "npm run build:codex:narration-real && playwright test -c extensions/codex/playwright.narration-real.config.ts",
    "test:narrate:playback-real": "npm run build:codex:narration-real && playwright test -c extensions/narrate/playwright.real.config.ts",
    "test:terminal-server": "cargo test --manifest-path extensions/terminal/server/Cargo.toml",
    "test:terminal-smoke": "node extensions/terminal/tests/ws-smoke.cjs",
    "test:terminal": "playwright test -c extensions/terminal/playwright.config.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.6.2",
    "@types/react": "~19.1.0",
    "@types/react-dom": "^19.1.9",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.1",
    "typescript": "~5.9.2",
    "vite": "^8.0.11"
  },
  "private": true,
  "packageManager": "npm@11.6.0"
}
