{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["v", "g"],
  "properties": {
    "v": { "type": "integer", "const": 1 },
    "g": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["i", "b", "x", "t"],
        "properties": {
          "i": { "type": "integer", "minimum": 0 },
          "b": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "items": { "type": "integer", "minimum": 0 }
          },
          "x": { "type": "string", "minLength": 1 },
          "t": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["x", "p", "s", "o"],
              "properties": {
                "x": { "type": "string", "minLength": 1 },
                "p": { "type": "string" },
                "s": {
                  "type": "array",
                  "items": { "type": "integer", "minimum": 0 }
                },
                "o": { "type": "string", "enum": ["h", "c", "g"] }
              }
            }
          }
        }
      }
    }
  }
}
