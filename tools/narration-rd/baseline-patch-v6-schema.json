{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["v", "g"],
  "properties": {
    "v": { "type": "integer", "const": 6 },
    "g": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["i", "s", "p"],
        "properties": {
          "i": { "type": "integer", "minimum": 0 },
          "s": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["i", "x"],
              "properties": {
                "i": { "type": "integer", "minimum": 0 },
                "x": { "type": "string", "minLength": 1, "maxLength": 4096 }
              }
            }
          },
          "p": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["i", "k", "x"],
              "properties": {
                "i": { "type": "integer", "minimum": 0 },
                "k": { "type": "string", "enum": ["a", "r"] },
                "x": { "type": "string", "minLength": 1, "maxLength": 256 }
              }
            }
          }
        }
      }
    }
  }
}
