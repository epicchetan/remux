{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["v", "g"],
  "properties": {
    "v": { "type": "integer", "const": 3 },
    "g": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["i", "o"],
        "properties": {
          "i": { "type": "integer", "minimum": 0 },
          "o": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["w", "p"],
              "properties": {
                "w": {
                  "type": "array",
                  "minItems": 2,
                  "maxItems": 2,
                  "items": { "type": "integer", "minimum": 0 }
                },
                "p": { "type": "string", "minLength": 1 }
              }
            }
          }
        }
      }
    }
  }
}
