{
  "name": "@remux/terminal",
  "private": true,
  "type": "module",
  "sideEffects": [
    "./viewer/src/styles.css",
    "@xterm/xterm/css/xterm.css"
  ],
  "exports": {
    ".": "./viewer/src/index.ts"
  },
  "scripts": {
    "build": "npm run build:state-worker && vite build --config viewer/vite.config.ts",
    "build:server": "npm run build:state-worker && cargo build --release --manifest-path server/Cargo.toml --target-dir /tmp/remux-terminal-server-target --quiet",
    "build:state-worker": "esbuild state-worker/src/main.ts --bundle --platform=node --format=esm --target=node20 --outfile=state-worker/dist/main.mjs",
    "test": "playwright test -c playwright.config.ts",
    "watch": "vite build --watch --config viewer/vite.config.ts"
  },
  "dependencies": {
    "@remux/viewer-kit": "*",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/addon-serialize": "0.14.0",
    "@xterm/headless": "6.0.0",
    "@xterm/xterm": "^6.0.0",
    "lucide-react": "^1.21.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "esbuild": "^0.27.0",
    "ws": "^7.5.10"
  }
}
