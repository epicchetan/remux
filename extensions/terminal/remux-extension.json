{
  "version": 1,
  "id": "terminal",
  "name": "Terminal",
  "display": {
    "title": "Terminal",
    "icon": "assets/terminal.png",
    "iconDark": "assets/terminal-dark.png"
  },
  "server": {
    "transport": "stdio",
    "build": {
      "command": "npm",
      "args": [
        "run",
        "build:server"
      ],
      "cwd": "."
    },
    "command": "/tmp/remux-terminal-server-target/release/remux-terminal-server",
    "args": [],
    "cwd": "."
  },
  "views": {
    "main": {
      "route": "/viewers/terminal",
      "entry": "viewer/dist/index.html",
      "cache": "immutable",
      "build": {
        "command": "npm",
        "args": [
          "run",
          "build"
        ],
        "cwd": "."
      },
      "watch": {
        "command": "npm",
        "args": [
          "run",
          "watch"
        ],
        "cwd": "."
      }
    }
  },
  "launchers": [
    {
      "id": "new-terminal",
      "view": "main",
      "label": "Terminal",
      "route": {
        "kind": "launch",
        "launch": "new-terminal",
        "resourceKind": "terminalSession"
      }
    }
  ],
  "fileHandlers": []
}
