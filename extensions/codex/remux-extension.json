{
  "version": 1,
  "id": "codex",
  "name": "Codex",
  "display": {
    "title": "Codex",
    "icon": "assets/codex.png",
    "iconDark": "assets/codex-dark.png"
  },
  "server": {
    "transport": "stdio",
    "build": {
      "command": "cargo",
      "args": [
        "build",
        "--release",
        "--manifest-path",
        "server/Cargo.toml",
        "--target-dir",
        "/tmp/remux-codex-server-target",
        "--offline",
        "--quiet"
      ],
      "cwd": "."
    },
    "command": "/tmp/remux-codex-server-target/release/remux-codex-server",
    "args": [],
    "cwd": "."
  },
  "views": {
    "main": {
      "route": "/viewers/codex",
      "entry": "viewer/dist/index.html"
    }
  },
  "launchers": [
    {
      "id": "new-chat",
      "view": "main",
      "label": "Codex",
      "route": {
        "kind": "launch",
        "launch": "new-chat",
        "resourceKind": "draft"
      }
    }
  ],
  "fileHandlers": []
}
