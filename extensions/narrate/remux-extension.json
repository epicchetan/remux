{
  "version": 2,
  "id": "narrate",
  "name": "Narrate",
  "display": {
    "title": "Narrate",
    "icon": "assets/markdown.png",
    "iconDark": "assets/markdown-dark.png"
  },
  "server": {
    "transport": "stdio",
    "build": {
      "command": "cargo",
      "args": [
        "build",
        "--release",
        "--manifest-path",
        "server/Cargo.toml",
        "--target-dir",
        "/tmp/remux-narrate-server-target",
        "--offline",
        "--quiet"
      ],
      "cwd": "."
    },
    "command": "/tmp/remux-narrate-server-target/release/remux-narrate-server",
    "args": [],
    "cwd": "."
  },
  "views": {
    "main": {
      "route": "/viewers/narrate",
      "entry": "viewer/dist/index.html",
      "cache": "immutable",
      "build": {
        "command": "npm",
        "args": [
          "run",
          "build"
        ],
        "cwd": "."
      },
      "watch": {
        "command": "npm",
        "args": [
          "run",
          "watch"
        ],
        "cwd": "."
      }
    }
  },
  "resources": {
    "workloads": {
      "narration": {
        "class": "background",
        "lifetime": "operation",
        "threads": 7
      }
    }
  },
  "launchers": [],
  "fileHandlers": [
    {
      "id": "narrate-viewer",
      "view": "main",
      "label": "Narrate",
      "extensions": [
        "md",
        "markdown",
        "mdown"
      ]
    }
  ]
}
