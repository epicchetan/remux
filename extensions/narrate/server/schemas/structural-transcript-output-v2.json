{
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "windowId", "blocks"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 2
    },
    "windowId": {
      "type": "integer",
      "minimum": 0
    },
    "blocks": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["blockId", "transcript"],
        "properties": {
          "blockId": {
            "type": "string",
            "minLength": 1,
            "maxLength": 1024
          },
          "transcript": {
            "type": "string",
            "minLength": 1,
            "maxLength": 65536
          }
        }
      }
    }
  }
}
