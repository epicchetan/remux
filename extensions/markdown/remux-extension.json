{
  "version": 1,
  "id": "markdown",
  "name": "Markdown",
  "display": {
    "title": "Markdown",
    "icon": "assets/markdown.png",
    "iconDark": "assets/markdown-dark.png"
  },
  "views": {
    "main": {
      "route": "/viewers/markdown",
      "entry": "viewer/dist/index.html",
      "cache": "immutable",
      "build": {
        "command": "npm",
        "args": [
          "run",
          "build"
        ],
        "cwd": "."
      },
      "watch": {
        "command": "npm",
        "args": [
          "run",
          "watch"
        ],
        "cwd": "."
      }
    }
  },
  "launchers": [],
  "fileHandlers": [
    {
      "id": "markdown-viewer",
      "view": "main",
      "label": "Markdown",
      "extensions": [
        "md",
        "markdown",
        "mdown"
      ]
    }
  ]
}
