{
  "expo": {
    "name": "Remux",
    "slug": "remux",
    "version": "1.0.1",
    "runtimeVersion": {
      "policy": "fingerprint"
    },
    "updates": {
      "url": "https://u.expo.dev/abbeb2c1-3062-4613-a034-3b7502d8b855"
    },
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "buildNumber": "2",
      "bundleIdentifier": "sh.remux.mobile",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#fafafa"
      },
      "backgroundColor": "#09090b",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "sh.remux.mobile"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Remux to attach photos to Codex messages."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#fafafa",
          "dark": {
            "backgroundColor": "#09090b"
          }
        }
      ],
      "expo-system-ui",
      "expo-status-bar",
      "expo-notifications"
    ],
    "extra": {
      "eas": {
        "projectId": "abbeb2c1-3062-4613-a034-3b7502d8b855"
      }
    },
    "owner": "shiv39"
  }
}
