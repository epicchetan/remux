{
  "name": "@remux/app",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "eas:whoami": "node scripts/eas-with-env.mjs whoami",
    "eas:device": "node scripts/eas-with-env.mjs device:create",
    "eas:devices": "node scripts/eas-with-env.mjs device:list --apple-team-id 7AS57BYX4Z",
    "eas:build:preview": "node scripts/eas-with-env.mjs build --platform ios --profile preview --non-interactive",
    "eas:build:production": "node scripts/eas-with-env.mjs build --platform ios --profile production --non-interactive",
    "eas:update:preview": "node scripts/eas-with-env.mjs update --channel preview --environment preview --non-interactive",
    "eas:update:production": "node scripts/eas-with-env.mjs update --channel production --environment production --non-interactive",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo/ui": "56.0.17",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@remux/viewer-kit": "*",
    "expo": "56.0.11",
    "expo-clipboard": "~56.0.4",
    "expo-document-picker": "~56.0.4",
    "expo-file-system": "~56.0.8",
    "expo-image-picker": "~56.0.17",
    "expo-keep-awake": "^56.0.3",
    "expo-notifications": "~56.0.18",
    "expo-splash-screen": "~56.0.11",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "expo-updates": "~56.0.19",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-view-shot": "5.1.0",
    "react-native-webview": "13.16.1",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@types/react": "~19.2.14",
    "typescript": "~6.0.3"
  },
  "private": true
}
